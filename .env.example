# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=0000000000:replace-me

# PostgreSQL: primary local DB is native PostgreSQL on the host.
POSTGRES_DB=postgres
POSTGRES_USER=nbeauty_app
POSTGRES_PASSWORD=app_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://nbeauty_app:app_password@localhost:5432/postgres
DATABASE_SCHEMA=nbeauty

# Used only when backend/bot run inside Docker and must reach host PostgreSQL.
DOCKER_DATABASE_URL=postgresql+asyncpg://nbeauty_app:app_password@host.docker.internal:5432/postgres

# JWT (сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET=replace-me-with-random-secret

# WebApp / Telegram auth
WEBAPP_URL=https://your-project.vercel.app
TELEGRAM_BOT_URL=https://t.me/your_bot_username

# Legacy fallback for old config. Keep empty in новых установках.
FRONTEND_URL=

# CORS (JSON массив)
CORS_ORIGINS=["http://localhost:3000","https://your-project.vercel.app"]

# Public URL of your LOCAL backend exposed through ngrok.
# Set this in Vercel env for the frontend deployment.
NEXT_PUBLIC_API_URL=https://your-backend.ngrok-free.app

# Only for local Next.js dev against a local backend.
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
ALLOWED_DEV_ORIGINS=

# Only for local frontend development in a browser.
# Skips Telegram auth and loads mock data. Never enable this in production.
NEXT_PUBLIC_DEV_AUTH_BYPASS=false
